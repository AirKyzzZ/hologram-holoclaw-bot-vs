# =============================================================================
# Hologram Generic AI Agent MCP VS — Configuration
# =============================================================================
#
# This file is read by the setup and start scripts.
# It contains all configuration needed for the AI Agent child service.
#
# For local testing:
#   source config.env
#   ./scripts/setup.sh
#   ./scripts/start.sh
#
# =============================================================================

# ---------------------------------------------------------------------------
# Network (derived from branch name in GHA; set manually for local usage)
# ---------------------------------------------------------------------------
# NETWORK="testnet"

# ---------------------------------------------------------------------------
# Veranad CLI account name
# ---------------------------------------------------------------------------
USER_ACC="org-vs-admin"

# ---------------------------------------------------------------------------
# Organization VS — parent service
# Set to the public URL of the organization-vs agent (K8s or local).
# The admin API is used to request Service credentials.
# ---------------------------------------------------------------------------
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL:-}"
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL%/}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL:-http://localhost:3000}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL%/}"

# ---------------------------------------------------------------------------
# VS Agent image and ports (local development)
# Use different ports than organization-vs to avoid collision.
# ---------------------------------------------------------------------------
VS_AGENT_IMAGE="${VS_AGENT_IMAGE:-veranalabs/vs-agent:latest}"
VS_AGENT_CONTAINER_NAME="hologram-ai-agent-vs"
VS_AGENT_ADMIN_PORT="3002"
VS_AGENT_PUBLIC_PORT="3003"

# ---------------------------------------------------------------------------
# Service details
# These appear in the Service credential issued by organization-vs.
# ---------------------------------------------------------------------------
SERVICE_NAME="Hologram AI Agent"
SERVICE_TYPE="AgentService"
SERVICE_DESCRIPTION="Generic AI agent verifiable service"
SERVICE_LOGO_URL="https://verana.io/logo.svg"
SERVICE_MIN_AGE="0"
SERVICE_TERMS="https://verana-labs.github.io/governance-docs/EGF/example.pdf"
SERVICE_PRIVACY="https://verana-labs.github.io/governance-docs/EGF/example.pdf"

# ---------------------------------------------------------------------------
# AnonCreds (optional — for authentication flow)
# Set to "true" to create an AnonCreds credential definition.
# ---------------------------------------------------------------------------
ENABLE_ANONCREDS="false"
ANONCREDS_NAME="avatar"
ANONCREDS_VERSION="1.0"
ANONCREDS_SUPPORT_REVOCATION="false"
CUSTOM_SCHEMA_BASE_ID="example"

# ---------------------------------------------------------------------------
# Chatbot configuration
# ---------------------------------------------------------------------------
CHATBOT_PORT="3010"

# LLM
LLM_PROVIDER="openai"
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_API_KEY="${OPENAI_API_KEY:-}"

# Agent pack
AGENT_PACK_PATH="./agent-packs/github-agent"

# RAG
RAG_PROVIDER="vectorstore"
RAG_DOCS_PATH="./docs"
RAG_REMOTE_URLS='[]'
VECTOR_STORE="redis"
VECTOR_INDEX_NAME="hologram-ia"
REDIS_URL="redis://localhost:6379"

# MCP (configured in agent-pack mcp.servers; override with MCP_SERVERS_CONFIG JSON array if needed)
# MCP_SERVERS_CONFIG='[]'

# PostgreSQL (runs in docker-compose)
POSTGRES_HOST="localhost"
POSTGRES_USER="hologram"
POSTGRES_PASSWORD="hologram"
POSTGRES_DB_NAME="hologram-agent"

# Memory
AGENT_MEMORY_BACKEND="memory"
AGENT_MEMORY_WINDOW="8"

# Auth
CREDENTIAL_DEFINITION_ID="${CREDENTIAL_DEFINITION_ID:-did:webvh:QmXtzkv1yXqnaTLbJ8ieydgMtTS8qugDisVvhT86xRodrQ:issuer-chatbot-vs.avatar.hologram.zone/resources/zQmcKU5BS6DBgH3r9rfYTnbaK7X1xdse5mTnbGW9WpSSabQ}"
ADMIN_AVATARS="${ADMIN_AVATARS:-}"

# Per-user MCP config encryption (32-byte hex key for AES-256-GCM)
MCP_CONFIG_ENCRYPTION_KEY="${MCP_CONFIG_ENCRYPTION_KEY:-}"

# MCP — GitHub MCP server
GITHUB_PERSONAL_ACCESS_TOKEN="${GITHUB_PERSONAL_ACCESS_TOKEN:-}"
GITHUB_MCP_URL="${GITHUB_MCP_URL:-https://api.githubcopilot.com/mcp/}"

# Logging
LOG_LEVEL="info"
